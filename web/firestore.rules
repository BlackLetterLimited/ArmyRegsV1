rules_version = "2";

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Member profiles and chat history.
    match /users/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();

      match /conversations/{conversationId} {
        allow read, write: if isOwner(uid) || isAdmin();

        match /messages/{messageId} {
          allow read, write: if isOwner(uid) || isAdmin();
        }
      }
    }

    // Optional admin role profile mirror (claims remain source of truth).
    match /admin_roles/{uid} {
      allow read, write: if isAdmin();
    }

    // Admin metrics: subcollections under `admin_metrics/default/` (hub doc must not repeat collection name).
    match /admin_metrics/{hubId}/user_aggregate_day/{docId} {
      allow read, write: if isAdmin() && hubId == "default";
    }
    match /admin_metrics/{hubId}/user_aggregate_month/{docId} {
      allow read, write: if isAdmin() && hubId == "default";
    }
    match /admin_metrics/{hubId}/user_aggregate_year/{docId} {
      allow read, write: if isAdmin() && hubId == "default";
    }
    match /admin_metrics/{hubId}/user_aggregate_provider/{docId} {
      allow read, write: if isAdmin() && hubId == "default";
    }

    match /admin_metrics/{hubId}/question_events/{docId} {
      allow read, write: if isAdmin() && hubId == "default";
    }
    match /admin_metrics/{hubId}/question_aggregate_day/{docId} {
      allow read, write: if isAdmin() && hubId == "default";
    }
    match /admin_metrics/{hubId}/question_aggregate_month/{docId} {
      allow read, write: if isAdmin() && hubId == "default";
    }
    match /admin_metrics/{hubId}/question_aggregate_year/{docId} {
      allow read, write: if isAdmin() && hubId == "default";
    }

    match /admin_metrics/{hubId}/regulation_aggregate/{regulationId} {
      allow read, write: if isAdmin() && hubId == "default";

      match /sources/{sourceId} {
        allow read, write: if isAdmin();
      }
    }

    match /admin_metrics/{hubId}/regulation_events/{docId} {
      allow read, write: if isAdmin() && hubId == "default";
    }

    // Default deny for all unlisted documents.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
