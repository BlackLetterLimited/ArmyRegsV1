# Backend API base URL (no trailing slash required).
# If blank/empty, requests go to same-origin '/api/jag-chat'.
NEXT_PUBLIC_BACKEND_API_BASE_URL=http://localhost:8000
#upon deployment, this variable is an issue with Railway, so it is not used.
#instead, the backend API base URL is set in the Railway dashboard, so this
#variable is not used in the main .env.local file.



# ---------------------------------------------------------------------------
# Firebase Admin SDK (server-side only — NEVER prefix with NEXT_PUBLIC_)
# Used by: app/api/auth/session/route.ts to verify & create session cookies.
#
# Option A (recommended for local dev):
#   Download your service account JSON from the Firebase Console:
#   Project Settings → Service Accounts → Generate new private key
#   Then base64-encode it:
#     Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("path/to/key.json"))
#     macOS/Linux:        base64 -i path/to/key.json
#   Paste the result here (single line, no whitespace):
FIREBASE_ADMIN_SERVICE_ACCOUNT=




