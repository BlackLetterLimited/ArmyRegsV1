# =============================================================
# web/.dockerignore
# Build context is the web/ directory.
# =============================================================

# Node dependencies (reinstalled inside the container by npm ci)
node_modules/

# Next.js build output (produced inside the container by npm run build)
.next/
out/

# Local environment files — secrets are injected at runtime via docker-compose
# or Railway service env vars, never baked into the image.
.env.local
.env.*.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS artefacts
.DS_Store
*.swp
*.swo
Thumbs.db

# TypeScript build info
*.tsbuildinfo
