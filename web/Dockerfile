# =============================================================================
# JAG-GPT Frontend — Next.js 14 standalone build
# =============================================================================
# This Dockerfile is used for LOCAL docker-compose testing.
# For Railway deployment, Railway's Nixpacks builder auto-detects Next.js
# and handles NEXT_PUBLIC_* env var injection correctly without a Dockerfile.
#
# Build context: ./web
#   docker build -f Dockerfile -t jaggpt-frontend \
#     --build-arg NEXT_PUBLIC_FIREBASE_API_KEY=... \
#     .
#
# NOTE: NEXT_PUBLIC_BACKEND_API_BASE_URL intentionally defaults to empty ("").
# An empty value is falsy in JS, so the built bundle falls back to the runtime
# BACKEND_API_BASE_URL env var (http://backend:8000) set by docker-compose.
# This keeps the internal Docker hostname out of the client bundle and routes
# browser calls through the server-side /api/jag-chat proxy instead.
# Do NOT give this a non-empty default — baking http://localhost:8000 or
# http://backend:8000 into the bundle will break Docker networking.
# =============================================================================

# ── Stage 1: Install dependencies ────────────────────────────────────────────
FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm ci

# ── Stage 2: Build ───────────────────────────────────────────────────────────
FROM node:22-alpine AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# NEXT_PUBLIC_* variables are inlined into the client bundle at build time.
# Pass them as build args (set in docker-compose build.args or `docker build --build-arg`).
ARG NEXT_PUBLIC_BACKEND_API_BASE_URL=
ARG NEXT_PUBLIC_FIREBASE_API_KEY
ARG NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN
ARG NEXT_PUBLIC_FIREBASE_PROJECT_ID
ARG NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET
ARG NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID
ARG NEXT_PUBLIC_FIREBASE_APP_ID
ARG NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID

ENV NEXT_PUBLIC_BACKEND_API_BASE_URL=$NEXT_PUBLIC_BACKEND_API_BASE_URL
ENV NEXT_PUBLIC_FIREBASE_API_KEY=$NEXT_PUBLIC_FIREBASE_API_KEY
ENV NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=$NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN
ENV NEXT_PUBLIC_FIREBASE_PROJECT_ID=$NEXT_PUBLIC_FIREBASE_PROJECT_ID
ENV NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=$NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET
ENV NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=$NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID
ENV NEXT_PUBLIC_FIREBASE_APP_ID=$NEXT_PUBLIC_FIREBASE_APP_ID
ENV NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=$NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID

ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

# ── Stage 3: Runtime ─────────────────────────────────────────────────────────
FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN addgroup --system --gid 1001 nodejs \
    && adduser --system --uid 1001 nextjs

# Copy public assets and the standalone build output.
COPY --from=builder /app/public ./public

RUN mkdir .next && chown nextjs:nodejs .next

# next.config.js `output: "standalone"` produces a self-contained server in
# .next/standalone/ — copy that plus the static assets it references.
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static    ./.next/static

USER nextjs

EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# server.js is generated by the standalone build.
CMD ["node", "server.js"]
